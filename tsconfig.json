{
  "compilerOptions": {
    "target": "es2021",
    "moduleResolution": "node",
    "module": "commonjs",
    "strict": true,
    "pretty": true,
    "allowJs": true,
    "noEmit": false,
    "sourceMap": true,
    "declaration": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./build",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@controllers/*": ["./controllers/*"],
      "@models/*": ["./models/*"],
      "@responses/*": ["./responses/*"],
      "@routes/*": ["./routes/*"],
      "@services/*": ["./services/*"]
    }
  }
}
